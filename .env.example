# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=****
NEXTAUTH_URL=***

# Google OAuth credentials (https://console.developers.google.com/)
GOOGLE_CLIENT_ID=****
GOOGLE_CLIENT_SECRET=****

# MongoDB connection string (e.g. MongoDB Atlas or local)
MONGODB_URI=****

# MinIO / S3-compatible storage
MINIO_ENDPOINT=http://localhost:9000

# MinIO Credentials
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Public base URL used by the browser to access uploaded files
MINIO_PUBLIC_URL=http://localhost:9000

AI_PROVIDER_API_KEY=***

WORKDIR=./workdir

# Git URL of the template repository cloned into WORKDIR when a new artifact is created
TEMPLATE_REPO_URL=https://github.com/apostrophecms/starter-kit-astro-apollo.git

NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055
CONFIG_PATH=/config
NEXT_PUBLIC_SERVICE_PROXY_URL=http://localhost:80

# Directus (CMS) — MCP server is enabled via MCP_ENABLED in docker-compose.yml
# KEY/SECRET generate with: openssl rand -hex 32
DIRECTUS_KEY=****
DIRECTUS_SECRET=****
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=****
DIRECTUS_DB_USER=directus
DIRECTUS_DB_PASSWORD=****
DIRECTUS_DB_DATABASE=directus