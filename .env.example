# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET="***"
NEXTAUTH_URL="http://localhost:3000"
# Google OAuth credentials (https://console.developers.google.com/)
GOOGLE_CLIENT_ID="***"
GOOGLE_CLIENT_SECRET="***"
# MongoDB connection string (e.g. MongoDB Atlas or local)
MONGODB_URI="mongodb://localhost:27017/pages-adu"
# Claude Code Token (`claude setup-token`)
CLAUDE_CODE_OAUTH_TOKEN="***"
# Path of workdir (where the code-repositories live)
WORKDIR=./workdir
# URL to service proxy (used for sandbox)
SERVICE_PROXY_URL=http://localhost
# URL to the documentation unit
DOCS_UNIT_URL=http://localhost:8082/sse

# Special variables
# Directus (CMS) — MCP server is enabled via MCP_ENABLED in docker-compose.yml
# KEY/SECRET generate with: openssl rand -hex 32
DIRECTUS_MCP_TOKEN=***
DIRECTUS_KEY=example
DIRECTUS_SECRET=secret
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=admin
DIRECTUS_DB_USER=directus
DIRECTUS_DB_PASSWORD=directus
DIRECTUS_DB_DATABASE=directus-1
# Directus file storage — uses the MinIO instance above as an S3-compatible backend.
# Bucket is created automatically by the minio-init service.
DIRECTUS_S3_BUCKET=directus-1